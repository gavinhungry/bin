#!/bin/bash

set -eo pipefail
shopt -s nullglob

source $(dirname "${BASH_SOURCE[0]}")/.abash/abash.sh

SCUP_DIR="/run/scup"
SERVICES=()

[ -d "$SCUP_DIR" ] || exit

for MARKER in "$SCUP_DIR"/*.service; do
  SERVICE=$(basename "$MARKER")
  MARKER_TIME=$(stat -c %Y "$MARKER")

  if ! systemctl is-active --quiet "$SERVICE"; then
    echo "$(color bold yellow)Removing stopped service marker$(color end) ($SERVICE)"
    arge dry-run || sudo rm "$MARKER"
    continue
  fi

  START_TIME_STR=$(systemctl show -p ActiveEnterTimestamp --value "$SERVICE" 2>/dev/null || true)

  if [[ -n "$START_TIME_STR" && "$START_TIME_STR" != "n/a" ]]; then
    SERVICE_TIME=$(date -d "$START_TIME_STR" +%s 2>/dev/null || echo 0)

    if [[ "$SERVICE_TIME" -gt "$MARKER_TIME" ]]; then
      echo "$(color bold yellow)Removing stale service marker$(color end) ($SERVICE)"
      arge dry-run || sudo rm "$MARKER"
      continue
    fi
  fi

  SERVICES+=("$SERVICE")
done

[ ${#SERVICES[@]} -gt 0 ] || exit 0

arge dry-run || sudo systemctl daemon-reload

for SERVICE in "${SERVICES[@]}"; do
  echo "$(color bold green)Restarting service$(color end) ($SERVICE)"
  if ! arge dry-run; then
    sudo systemctl try-restart "$SERVICE"
    sudo rm "$SCUP_DIR/$SERVICE"
  fi
done
