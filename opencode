#!/bin/bash

source $(dirname "${BASH_SOURCE[0]}")/.abash/abash.sh

load_api_key() {
  local VAR_NAME=$1
  local API_KEY

  if API_KEY=$(pass "opencode/${VAR_NAME}" 2> /dev/null); then
    export "$VAR_NAME"="$API_KEY"
  fi
}

if unlock-pass; then
  load_api_key ANTHROPIC_API_KEY
  load_api_key GOOGLE_GENERATIVE_AI_API_KEY
  load_api_key OPENAI_API_KEY
fi

export EDITOR="drain-stdin $EDITOR"

# optionally symlink ${XDG_DATA_HOME}/opencode to ${OPENCODE_CACHE_DIR}
OPENCODE_CACHE_DIR=${XDG_CACHE_HOME}/.opencode
if [ ! -d "$OPENCODE_CACHE_DIR" ]; then
  mkdir -m 700 "$OPENCODE_CACHE_DIR"
fi

OPENCODE_INSTALL_DIR=$(
  pnpm -g list --long --json |
  jq -r '.[0].dependencies["opencode-linux-x64"].path'
)

[ -d "$OPENCODE_INSTALL_DIR" ] || die 'opencode not installed'

OPENCODE="$OPENCODE_INSTALL_DIR"/bin/opencode
exec $OPENCODE "$@"
