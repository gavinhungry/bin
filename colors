#!/bin/bash

RESET=$(tput sgr0)
WIDTH=12

COLORS=(BLACK RED GREEN YELLOW BLUE MAGENTA CYAN WHITE)

cell() {
  local ESC='0' COLOR=$1 NAME=$2 STYLE=$3

  case "$STYLE" in
    DIM) ESC='2' ;;
    BOLD_DIM) ESC='1;2' ;;
    BOLD) ESC='1' ;;
    NORMAL) ESC='0' ;;
  esac

  local _STYLE="$STYLE"
  local LABEL="${STYLE}_${NAME}"

  if [ "$STYLE" == 'NORMAL' ]; then
    _STYLE=''
    LABEL="$NAME"
  fi

  local _WIDTH=$((WIDTH + ${#_STYLE}))
  printf '\e[%s;%sm%-*s%s' "$ESC" "$COLOR" "$_WIDTH" "$LABEL" "$RESET"
}

echo

for I in "${!COLORS[@]}"; do
  COLOR=$((30 + I))
  NAME=${COLORS[I]}

  printf '%-4s' "$I"
  cell "$COLOR" "$NAME" DIM
  cell "$COLOR" "$NAME" BOLD_DIM
  cell "$COLOR" "$NAME" NORMAL
  cell "$COLOR" "$NAME" BOLD
  printf '\n'
done

printf '%s\n' "$RESET"
