#!/bin/bash

source $(dirname "${BASH_SOURCE[0]}")/.abash/abash.sh

lspci -mm | grep 'VGA compatible controller\|3D controller\|Graphics' | while read -r VGA ; do
  VENDOR=$(echo $VGA | cut -d'"' -f4 | sed 's/ Corporation//g')
  MODEL_FULL=$(echo $VGA | cut -d'"' -f6)
  MODEL_NAME=$(echo $MODEL_FULL | cut -d'[' -f2 | cut -d']' -f1 | sed -E 's/^(.*)Rev\. .*/\1/')
  MODEL_NUM=$(echo $MODEL_FULL | cut -d'[' -f1)

  if [ "$MODEL_FULL" != "$MODEL_NUM" ]; then
    OUTPUT="$VENDOR ${MODEL_NAME% }"

    if arge model; then
      OUTPUT+=" (${MODEL_NUM% })"
    fi

    echo "$OUTPUT"

    continue
  fi

  echo "$VENDOR $MODEL_FULL"
done
