#!/bin/bash

source $(dirname "${BASH_SOURCE[0]}")/.abash/abash.sh

arge ccd &&
  TEMP_CMD=ccd-temp ||
  TEMP_CMD=cpu-temp

UTIL=$(cpu-util || echo ?)
THRESHOLD=$(arg threshold)
USAGE=${UTIL%\%}

if [ -n "$THRESHOLD" ]; then
  if [[ "$USAGE" =~ ^[0-9]+$ ]] && [ "$USAGE" -ge "$THRESHOLD" ]; then
    DOT='● '
  else
    DOT='○ '
  fi
fi

OUTPUT="${UTIL} • $($TEMP_CMD || echo ?)"
echo "${DOT}$(enpad "$OUTPUT" $(arg width 0))"
