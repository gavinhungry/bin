#!/bin/bash

set -eo pipefail
source $(dirname "${BASH_SOURCE[0]}")/.abash/abash.sh

[ $# -ge 1 ] || usage 'FILE [FILE ...]'

for ARG in "$@"; do
  if [ ! -e "$ARG" ]; then
    warn "$ARG does not exist"
    continue
  fi

  if [ ! -r "$ARG" ]; then
    warn "$ARG is not readable"
    continue
  fi

  if (
    [[ $TERM == xterm* ]] ||
    [ $TERM = 'screen' ] ||
    [ -n "$XDG_CURRENT_DESKTOP" ]
  ); then
    exec ${EDITOR_GUI:-subl} "$ARG" &> /dev/null &
  else
    exec ${EDITOR:-emacs} "$ARG"
  fi
done
